generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostCategory {
  DAILY_RHYTHM
  FOOD_THERAPY
  HERBAL_WISDOM
  MOVEMENT
  SEASONAL_CARE
}

model Post {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  summary     String
  body        String
  category    PostCategory @default(DAILY_RHYTHM)
  published   Boolean      @default(true)
  publishedAt DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([published, publishedAt])
}
